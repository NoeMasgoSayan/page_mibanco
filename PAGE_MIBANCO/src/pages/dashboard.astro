---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Dashboard">

<div class="container-fluid">
  <div class="row">

    <!-- SIDEBAR -->
    <nav class="col-md-2 d-none d-md-block sidebar p-0">
      <div class="text-center py-4 bg-mibanco-green">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/MiBanco_logo.svg/1200px-MiBanco_logo.svg.png"
             alt="MiBanco" height="30" class="mb-2">
        <p class="text-white small mb-0">Portal de Talento Humano</p>
      </div>

      <a href="/dashboard" class="active">
        <i class="fas fa-users me-2"></i> Candidatas
      </a>

      <a href="#">
        <i class="fas fa-briefcase me-2"></i> Vacantes
      </a>

      <a href="#">
        <i class="fas fa-chart-pie me-2"></i> Reportes
      </a>

      <a href="/" class="mt-5">
        <i class="fas fa-sign-out-alt me-2"></i> Volver
      </a>
    </nav>

    <!-- MAIN -->
    <main class="col-md-10 ms-sm-auto px-md-4 py-4">

      <!-- HEADER -->
      <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h1 class="h2 fw-bold text-mibanco-green">
          Resultados de Match Automático 🔥
        </h1>

        <button class="btn btn-sm btn-outline-secondary">
          <i class="fas fa-download me-1"></i> Exportar
        </button>
      </div>

      <!-- FILTROS -->
      <div class="row mb-4">
        <div class="col-md-4">
          <select class="form-select shadow-sm">
            <option selected>Filtrar por Vacante</option>
            <option>Frontend Junior</option>
            <option>Practicante</option>
            <option>Full-Stack</option>
          </select>
        </div>

        <div class="col-md-8">
          <input type="text" class="form-control shadow-sm"
                 placeholder="Buscar por nombre o habilidades...">
        </div>
      </div>

      <!-- TABLA -->
      <div class="table-responsive shadow-sm rounded-4 bg-white">

        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Candidata</th>
              <th>Ubicación</th>
              <th>Habilidades</th>
              <th>Match</th>
              <th>Acciones</th>
            </tr>
          </thead>

          <tbody>

            <!-- FILA -->
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar-circle bg-mibanco-green text-white me-3">
                    LC
                  </div>
                  <div>
                    <h6 class="mb-0 fw-bold">Lucía Campos</h6>
                    <small class="text-muted">Egresada</small>
                  </div>
                </div>
              </td>

              <td>Lima</td>
              <td>HTML, CSS, React</td>

              <td>
                <span class="badge match-high px-3 py-2 rounded-pill">
                  🔥 95%
                </span>
              </td>

              <td>
                <button class="btn btn-sm btn-mibanco-green text-white">
                  Ver
                </button>
              </td>
            </tr>

            <!-- FILA -->
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar-circle bg-secondary text-white me-3">
                    MR
                  </div>
                  <div>
                    <h6 class="mb-0 fw-bold">María Rodríguez</h6>
                    <small class="text-muted">Estudiante</small>
                  </div>
                </div>
              </td>

              <td>Arequipa</td>
              <td>JS, SQL</td>

              <td>
                <span class="badge match-medium px-3 py-2 rounded-pill">
                  75%
                </span>
              </td>

              <td>
                <button class="btn btn-sm btn-mibanco-green text-white">
                  Ver
                </button>
              </td>
            </tr>

          </tbody>
        </table>

      </div>

    </main>
  </div>
</div>

</MainLayout>